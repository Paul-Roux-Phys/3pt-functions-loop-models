Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "check", " ", "that", " ", "all", " ", "algebraic", " ", "relations", " ", 
    "are", " ", "verified"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"algRel", " ", "=", " ", 
     RowBox[{"Join", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"e", "[", "i", "]"}], ".", 
           RowBox[{"e", "[", "i", "]"}]}], " ", "-", " ", 
          RowBox[{"n", "*", 
           RowBox[{"e", "[", "i", "]"}]}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"i", ",", " ", "1", ",", " ", "4"}], "}"}]}], "]"}], ",", 
       " ", 
       RowBox[{"(*", " ", 
        TemplateBox[<|"boxes" -> FormBox[
            RowBox[{
              SubsuperscriptBox[
               StyleBox["e", "TI"], 
               StyleBox["i", "TI"], "2"], "\[LongEqual]", 
