Cell[TextData[{
 "To compute the action of the generators ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["e", "TI"], 
        StyleBox["i", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "e_i", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e07b1765-387d-46a5-81b0-cc8ffa6b8ea0"],
 " we compute ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["e", "TI"], "1"], TraditionalForm], "errors" -> {}, "input" -> 
     "e_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a5a177cd-4fc8-4aa0-a752-f824a418d32e"],
 " and define ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["e", "TI"], 
          StyleBox["i", "TI"]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["u", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], "-", "1"}]], 
         SubscriptBox[
          StyleBox["e", "TI"], "1"], 
         SuperscriptBox[
          StyleBox["u", "TI"], 
          RowBox[{"1", "-", 
            StyleBox["i", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "e_i = u^{i-1} e_1 u^{1-i}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0d4c09f8-18c4-4f21-b00b-b0e14993d5e4"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["u", "TI"], TraditionalForm], "errors" -> {}, "input" -> "u", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7922f0d3-f1e9-4623-a702-ce046141f50a"],
 " is the translation operator."
}], "Text",
 CellChangeTimes->{{3.952398888321138*^9, 3.9523989778381767`*^9}, {
  3.9523990156839113`*^9, 3.952399161974862*^9}, {3.952399205189217*^9, 
