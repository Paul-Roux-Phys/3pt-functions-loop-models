Cell[TextData[{
 "Three-point function ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LeftAngleBracket]", 
         SubsuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{"(", 
            RowBox[{"1", ",", "0"}], ")"}], "3"], "\[RightAngleBracket]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\left\\langle V_{(1, 0)}^3\\right\\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cb7df81f-1133-415c-95f6-954262f79cf4"],
 " of the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["PSU", FontSlant -> "Plain"], "(", 
         StyleBox["n", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathrm{PSU}(n)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6802346d-93b8-45ed-a236-6496ac9dfe97"],
 " model on the cylinder of size 4"
}], "Title",
 CellChangeTimes->{{3.95239850801723*^9, 3.952398556855081*^9}, {
  3.952398639435801*^9, 3.952398704433144*^9}, {3.952398899121767*^9, 
  3.9523989005227737`*^9}},ExpressionUUID->"78ba9f25-84ed-46f7-9f50-\
14620372e1b7"],

