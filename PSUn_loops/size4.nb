 CellLabel->
  "In[171]:=",ExpressionUUID->"cc8ed300-4388-4732-8040-e023bdadd79f"],

Cell[TextData[{
 "The module ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["W", "TI"], 
        RowBox[{"(", 
          RowBox[{"0", ",", "0"}], ")"}]], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathcal{W}_{(0, 0)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "051aa1e7-3678-43ef-b7cc-e6bf87428782"],
 " for the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["PSU", FontSlant -> "Plain"], "(", 
         StyleBox["n", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathrm{PSU}(n)", "state" -> "TeX"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "963faa52-a1c6-4f69-b496-029aaa0b556a"],
 " model in size ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[ScriptL]", "\[LongEqual]", "4"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\ell = 4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a96f8365-92bc-4f24-b6c1-9bd768bd2295"],
 " has two states labelled ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|1", "\[RightAngleBracket]", "\[LongEqual]", 
         RowBox[{"(", "12", ")"}], 
         RowBox[{"(", "34", ")"}], ",", "|2", "\[RightAngleBracket]", 
         "\[LongEqual]", 
         RowBox[{"(", "14", ")"}], 
         RowBox[{"(", "23", ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "|1\\rangle = (12)(34), |2\\rangle = (14)(23)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "072eead4-e2b6-44d4-adfc-7296e856203d"],
 ".\nThe module ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["W", "TI"], 
        RowBox[{"(", 
          RowBox[{"1", ",", "0"}], ")"}]], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathcal{W}_{(1, 0)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "421cceea-3d4f-492a-8729-7644e999431d"],
 " for the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["PSU", FontSlant -> "Plain"], "(", 
         StyleBox["n", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathrm{PSU}(n)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2998771a-803a-4ef6-bcf2-4babc909ceb6"],
 " model in size ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"\[ScriptL]", "\[LongEqual]", "4"}], TraditionalForm], 
      "errors" -> {}, "input" -> "\\ell = 4", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"], " "}], TraditionalForm]],ExpressionUUID->
  "a7bee92f-ebad-4f13-9217-b884570f3525"],
 "has 4 states. To compute three-point functions, we need to introduce labels \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["R", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["R", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "R_1, R_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e1abd43e-df13-48b4-b90f-ed5d5806aa65"],
 " on the defects indicating where they are coming from. We label the states \
in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["W", "TI"], 
        RowBox[{"(", 
          RowBox[{"1", ",", "0"}], ")"}]], TraditionalForm], "errors" -> {}, 
     "input" -> "\\mathcal W_{(1, 0)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d17f24ea-584c-486c-9e16-06a6d0833b1e"],
 "as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|4", 
         StyleBox["i", "TI"], 
         StyleBox["j", "TI"], "+", 
         StyleBox["a", "TI"], "\[RightAngleBracket]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|4ij + a\\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5d32f0e7-2a84-4dea-968e-48463b7f7faf"],
 ", where i and j are the positions of the two defects, and a indicates the \
labels: R_1 R_1 <=> a=0  R_1 R_2 <=> a=1  R_2 R_1 <=> a=2 R_2 R_2 <=> a=4\n \
Thus, the computation of all the\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["Z", "TI"], 
          RowBox[{
            SubscriptBox[
             StyleBox["p", "TI"], "1"], ",", 
            SubscriptBox[
             StyleBox["p", "TI"], "2"], ",", 
            SubscriptBox[
             StyleBox["p", "TI"], "3"]}]], "\[LongEqual]", 
         RowBox[{"\[LeftAngleBracket]", 
           RowBox[{
             SubscriptBox["\[Psi]", 
              SubscriptBox[
               StyleBox["p", "TI"], "3"]], "|", 
             SuperscriptBox[
              StyleBox["T", "TI"], 
              StyleBox["M", "TI"]], 
             SubscriptBox[
              StyleBox["O", "TI"], 
              SubscriptBox[
               StyleBox["p", "TI"], "2"]], 
             SuperscriptBox[
              StyleBox["T", "TI"], 
              StyleBox["M", "TI"]], "|", 
             SubscriptBox["\[Psi]", 
              SubscriptBox[
               StyleBox["p", "TI"], "2"]]}], "\[RightAngleBracket]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "Z_{p_1, p_2, p_3} = \\langle \\psi_{p_3} | T^M \\mathcal O_{p_2}  T^M| \
\\psi_{p_2} \\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8f478fe8-ef3a-476d-a4cd-f5bb9d35109f"],
 "\nfor the three point function ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[LeftAngleBracket]", 
         SubsuperscriptBox[
          StyleBox["V", "TI"], 
          RowBox[{"(", 
            RowBox[{"1", ",", "0"}], ")"}], "3"], "\[RightAngleBracket]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\left\\langle V_{(1, 0)}^3\\right\\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "daa0c001-da63-4c05-a471-a0c3fbad8c20"],
 "  involves link patterns with 0, 2 or 4 defects, and with labels ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["R", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["R", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "R_1, R_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7819c082-b3d1-4def-9bd5-956b19c96b4e"],
 " indicating where the labels come from. We call ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"|1", "\[RightAngleBracket]"}], TraditionalForm], 
     "errors" -> {}, "input" -> "|1\\rangle", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "761e4c26-762f-484a-be9d-a8b576ce78b6"],
 " the state with defects at positions 1 and 2, and labels ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["R", "TI"], "1"], ",", 
         SubscriptBox[
          StyleBox["R", "TI"], "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "R_1, R_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a939dbd5-0178-4ba3-ae46-a964469d836b"],
 "\n\nWe construct the transfer matrix\n",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["T", "TI"], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             SubscriptBox[
              StyleBox["e", "TI"], "1"]}], ")"}], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             SubscriptBox[
              StyleBox["e", "TI"], "3"]}], ")"}], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             SubscriptBox[
              StyleBox["e", "TI"], "2"]}], ")"}], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             SubscriptBox[
              StyleBox["e", "TI"], "4"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "T = (1+e_1)(1+e_3)(1+e_2)(1+e_4)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d3f7750a-3f89-40a4-baf2-ea207ba3c687"],
 "\nand the operator ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["O", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "\\mathcal{O}_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "10037d36-5535-4d02-abb0-695a2db2d962"],
 " defined in the draft paper PottsOn/articles/three-point/vvv_loops.tex."
}], "Text",
 CellChangeTimes->{{3.952398888321138*^9, 3.9523989778381767`*^9}, {
   3.9523990156839113`*^9, 3.952399161974862*^9}, {3.952399205189217*^9, 
